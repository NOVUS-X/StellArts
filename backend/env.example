# Database
DATABASE_URL=postgresql://user:password@localhost:5432/stellarts_db

# Security
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API
API_V1_STR=/api/v1
PROJECT_NAME=Stellarts
DEBUG=True

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# Email (for future use)
SMTP_TLS=True
SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_USER=
SMTP_PASSWORD=

# Frontend URL used for verification links
FRONTEND_URL=http://localhost:3000

# External APIs (for future use)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Bill of materials pricing (Traject BigBox Home Depot product API or compatible JSON)
# https://docs.trajectdata.com/bigboxapi/homedepot-product-data-api/overview
RETAIL_PRODUCT_API_KEY=
RETAIL_PRODUCT_API_BASE_URL=https://api.bigboxapi.com/request
RETAIL_PRODUCT_MERCHANT_LABEL=homedepot
